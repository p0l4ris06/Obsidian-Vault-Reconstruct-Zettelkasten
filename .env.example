# Example environment configuration for Vault Reconstruct
# Copy to `.env` and fill in your values.
#
# DO NOT commit real secrets.

# ----------------------------
# Vault paths (optional)
# ----------------------------
# Default in code matches this repo (override only if you use a different vault):
# VAULT_PATH=C:\\Users\\Wren C\\Documents\\Coding stuff\\Obsidian Vault
# VAULT_INPUT_PATH=
# VAULT_OUTPUT_PATH=

# ----------------------------
# Provider selection
# ----------------------------
# VAULT_LLM_PROVIDER=ollama

# ----------------------------
# Ollama (local / cloud)
# ----------------------------
OLLAMA_HOST=http://localhost:11434
# OLLAMA_API_KEY=
# VAULT_OLLAMA_MODEL=qwen2.5-coder:0.5b-base-q8_0
# VAULT_OLLAMA_CLOUD_MODEL=gemma4:31b-cloud

# ----------------------------
# Gemini
# ----------------------------
# GEMINI_API_KEY=
# VAULT_GEMINI_MODEL=gemini-2.5-flash

# ----------------------------
# Azure OpenAI
# ----------------------------
# AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-10-21
# VAULT_AZURE_MODEL=<your-deployment-name>

# ----------------------------
# Anki exporter (optional)
# ----------------------------
# ANKI_OUTPUT_DIR=C:\\Users\\<you>\\Documents\\Anki Decks
# ANKI_TRACKER_FILE=anki_tracker.json
# ANKI_DECK_PREFIX=Vet Nursing
# ANKI_REQUEST_DELAY=0.4
# ANKI_MAX_RETRIES=3

