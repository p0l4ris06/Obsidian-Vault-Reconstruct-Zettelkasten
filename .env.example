# Vault Reconstruct: Environment Template
# Copy to `.env` and fill in your values.
# DO NOT commit real secrets to version control.

# ----------------------------------------------------------------------------
# Vault Paths (IMPORTANT: Configure this for your setup)
# ----------------------------------------------------------------------------
# VAULT_PATH: Main vault directory. Can be absolute or relative path.
# If not set, falls back to ../Obsidian Vault (relative to repo root).
# Example: C:\Users\YourName\Documents\Obsidian Vault
# VAULT_PATH=

# Alternative: Set input and output paths separately
# VAULT_INPUT_PATH=
# VAULT_OUTPUT_PATH=

# NOTE: The vault path MUST exist. The application will validate on startup.

# ----------------------------------------------------------------------------
# Backend Selection
# ----------------------------------------------------------------------------
# Choose your active AI provider: ollama, gemini, azure, or autoresearch (local)
VAULT_LLM_PROVIDER=ollama

# ----------------------------------------------------------------------------
# 1. Ollama (Local or Cloud-managed)
# ----------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434

# Recommended model for high-quality grounded research synthesis:
VAULT_OLLAMA_MODEL=qwen2.5-coder:3b

# Optional: Cloud-managed Ollama (e.g. via OLLAMA_API_KEY)
# OLLAMA_API_KEY=
# VAULT_OLLAMA_CLOUD_MODEL=gemma4:31b

# ----------------------------------------------------------------------------
# 2. Google Gemini & HuggingFace
# ----------------------------------------------------------------------------
GEMINI_API_KEY=your_key_here
VAULT_GEMINI_MODEL=gemini-2.0-flash

# OPTIONAL: HuggingFace Token (for higher RAG model download rate limits)
HF_TOKEN=

# ----------------------------------------------------------------------------
# 3. Azure OpenAI
# ----------------------------------------------------------------------------
# AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_key_here
# AZURE_OPENAI_API_VERSION=2024-10-21
# VAULT_AZURE_MODEL=your_deployment_name

# ----------------------------------------------------------------------------
# 4. Local Autoresearch (Experimental)
# ----------------------------------------------------------------------------
# Points to the custom-trained model binaries
# AUTORESEARCH_MODEL_PATH=./autoresearch/model.pt

# ----------------------------------------------------------------------------
# Anki Configuration
# ----------------------------------------------------------------------------
# ANKI_OUTPUT_DIR=C:\\Path\\To\\Export
# ANKI_DECK_PREFIX=Vault
# ANKI_REQUEST_DELAY=0.4

# ----------------------------------------------------------------------------
# Developer Mode
# ----------------------------------------------------------------------------
# Disable SSL verification for PubMed if your network is strict
# PYTHONWARNINGS=ignore:No parser was explicitly specified
